# ─────────────────────────────────────────────────────────────────────────────
# Steward env template. Copy to apps/web/.env.local and apps/worker/.env and fill.
# NEVER commit a real .env — it is gitignored. Default cluster is devnet.
# ─────────────────────────────────────────────────────────────────────────────

# --- Solana / RPC (Helius) ---
SOLANA_CLUSTER=devnet
HELIUS_API_KEY=
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
# Public RPC consumed by the browser (safe subset / proxied in prod)
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# --- Privy (embedded wallets, email auth) ---
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Squads V4 (org treasury multisig) ---
# Created per-org at onboarding; this is an optional default for local dev.
SQUADS_PROGRAM_ID=SQDS4ep65T869zMMBKyuUq6aD6EgTu8psMjkvj52pCf

# --- Stablecoin mint (USDC). Devnet USDC differs from mainnet. ---
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# --- Fiat ramps ---
# Card / Apple Pay / Google Pay -> USDC on Solana (Stripe Crypto Onramp)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# ACH / wire -> USDC on Solana (Bridge virtual accounts)
BRIDGE_API_KEY=
BRIDGE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM="Steward <receipts@example.org>"

# --- Datastores ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/steward
REDIS_URL=redis://localhost:6379

# --- Fee sponsorship ---
# Sponsor keypair (base58) that pays SOL fees so users never hold SOL.
# In prod, front this with a Kora relayer; never ship a hot key to the browser.
FEE_PAYER_SECRET_KEY=
